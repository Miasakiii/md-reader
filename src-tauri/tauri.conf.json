{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "MD Reader",
  "version": "1.1.1",
  "identifier": "com.mdreader.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MD Reader",
        "width": 1100,
        "height": 750,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "center": true,
        "dragDropEnabled": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost http://localhost:1420; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:1420; style-src 'self' 'unsafe-inline' http://localhost:1420; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420; img-src 'self' asset: http://asset.localhost blob: data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "app", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      },
      "wix": {
        "language": {
          "zh-CN": {
            "localePath": "./wix/zh-CN.wxl"
          }
        }
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "fileAssociations": [
      {
        "ext": ["md"],
        "mimeType": "text/markdown",
        "description": "Markdown 文件"
      },
      {
        "ext": ["markdown"],
        "mimeType": "text/markdown",
        "description": "Markdown 文件"
      }
    ],
    "category": "Utility",
    "shortDescription": "轻量级 Markdown 阅读器"
  }
}
